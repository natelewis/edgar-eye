# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
DATABASE_URL="postgresql://alpha:alpha@localhost:5433/alpha_trading?schema=public"

POSTGRES_USER=alpha
POSTGRES_PASSWORD=alpha
POSTGRES_DB=alpha_trading
POSTGRES_PORT=5433

# =============================================================================
# Trading mode & broker (Alpaca)
# =============================================================================
TRADING_MODE=PAPER

ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets

# =============================================================================
# Local LLM inference (OpenAI-compatible / Ollama)
# =============================================================================
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=ollama

# =============================================================================
# SEC EDGAR ingestion
# =============================================================================
SEC_USER_AGENT="WhaleWatch_LocalBot admin@example.com"
SEC_WATCH_TICKERS=AAPL,MSFT,GOOGL
SEC_POLL_INTERVAL_MS=5000

# =============================================================================
# Risk guardrails
# =============================================================================
MAX_DAILY_DRAWDOWN_PCT=5
MAX_POSITION_SIZE_PCT=20
MAX_CONSECUTIVE_LLM_FAILURES=3

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Optional API key for REST + WebSocket auth (leave empty in local dev)
API_SECRET_KEY=

# Disk cache for immutable Alpaca historical data (backtests)
HISTORICAL_DATA_CACHE_DIR=.cache/historical-data
